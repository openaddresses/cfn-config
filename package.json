{
    "name": "@openaddresses/cfn-config",
    "type": "module",
    "version": "8.0.0",
    "author": "Mapbox",
    "description": "Quickly configure and start AWS CloudFormation stacks",
    "license": "BSD-2-Clause",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE",
        "CHANGELOG.md"
    ],
    "engines": {
        "node": ">= 22"
    },
    "repository": {
        "url": "https://github.com/openaddresses/cfn-config.git",
        "type": "git"
    },
    "scripts": {
        "test": "tsx --test test/**.test.ts",
        "lint": "eslint index.ts lib/*.ts test/*.ts",
        "build": "tsc --build",
        "pretest": "npm run lint"
    },
    "dependencies": {
        "@aws-sdk/client-cloudformation": "^3.272.0",
        "@aws-sdk/client-kms": "^3.272.0",
        "@aws-sdk/client-s3": "^3.272.0",
        "@openaddresses/s3urls": "^4.1.1",
        "colors": "1.4.0",
        "diff": "^8.0.0",
        "easy-table": "^1.0.0",
        "inquirer": "^13.0.0",
        "json-diff": "^1.0.0",
        "json-stable-stringify": "^1.0.2"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/diff": "^7.0.2",
        "@types/inquirer": "^9.0.3",
        "@types/json-diff": "^1.0.0",
        "@types/json-stable-stringify": "^1.0.34",
        "@types/node": "^25.0.0",
        "@types/sinon": "^21.0.0",
        "eslint": "^10.0.0",
        "opener": "^1.4.1",
        "sinon": "^21.0.0",
        "tsx": "^4.19.4",
        "typescript": "^5.0.0",
        "typescript-eslint": "^8.31.1"
    }
}
