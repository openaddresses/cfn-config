{
    "compilerOptions": {
        "module": "es2022",
        "esModuleInterop": true,
        "target": "es2022",
        "declaration": true,
        "declarationMap": true,
        "noImplicitAny": true,
        "moduleResolution": "node",
        "sourceMap": true,
        "rootDir": ".",
        "outDir": "./dist",
        "baseUrl": ".",
        "paths": {
            "*": [
                "node_modules/*"
            ]
        }
    },
    "include": [
        "index.ts",
        "lib/**/*.ts"
    ]
}
